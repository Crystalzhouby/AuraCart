<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="start"
    android:paddingStart="14dp" android:paddingEnd="48dp"
    android:paddingTop="4dp" android:paddingBottom="4dp">
    <ImageView android:id="@+id/ivAvatar"
        android:layout_width="32dp" android:layout_height="32dp"
        android:src="@drawable/guide_face"
        android:background="@drawable/bg_avatar"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:layout_marginEnd="8dp" android:layout_marginTop="2dp"/>
    <TextView android:id="@+id/tvText"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="@drawable/bg_ai_bubble"
        android:textColor="@color/colorTextPrimary" android:textSize="14sp"
        android:lineSpacingMultiplier="1.55" android:paddingStart="14dp"
        android:paddingEnd="14dp" android:paddingTop="10dp" android:paddingBottom="10dp"
        android:elevation="2dp"/>
</LinearLayout>
